# claude bot (默认 backend = claude_code)
TG_BOT_TOKEN=xxx:yyy

# codex bot (可选, 若启用 codex backend 才需要)
# TG_CODEX_BOT_TOKEN=xxx:yyy

# 留 0 = setup mode: bot 收到第一条 DM 自动锁定发送者 user_id 并写回此文件
BOSS_USER_ID=0
LOG_LEVEL=INFO

# AI CLI binary paths (optional but recommended for systemd/tmux deployments).
# Use the native Claude Code binary when possible; this avoids broken npm
# optional-dependency installs and shell PATH differences.
# CLAUDE_BIN=/home/you/.local/bin/claude
# CODEX_BIN=/home/you/.npm-global/bin/codex

# ── 飞书 (可选, 仅 bindings.yaml 有 channel=feishu 的 binding 才需要) ──
# bot_token_env=FEISHU 的 binding 读这组; 多套 app 用 FEISHU2_APP_ID 等前缀区分
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=yyy
# Boss open_id 白名单 (逗号分隔), 在飞书发任意消息看 bot 日志打印的 open_id
# FEISHU_BOSS_OPEN_IDS=ou_xxx,ou_yyy
